# i3 config
set $mod Mod4

# Font
font pango:JetBrainsMono Nerd Font 8

# Terminal
bindsym $mod+Return exec --no-startup-id i3-msg split toggle && ghostty

# Browser
bindsym $mod+p exec google-chrome-stable

# Thunar
bindsym $mod+o exec Thunar

# Kill window
bindsym $mod+q kill

# Launcher
bindsym $mod+d exec rofi -show drun

# Reload config
bindsym $mod+Shift+r restart

# Logout
bindsym $mod+Shift+e exec i3-nagbar -t warning -m 'Exit i3?' -B 'Yes' 'i3-msg exit'

# Focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Move windows
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Workspaces
bindsym $mod+1 workspace 1
bindsym $mod+2 workspace 2
bindsym $mod+3 workspace 3
bindsym $mod+4 workspace 4
bindsym $mod+5 workspace 5

bindsym $mod+Shift+1 move container to workspace 1
bindsym $mod+Shift+2 move container to workspace 2
bindsym $mod+Shift+3 move container to workspace 3
bindsym $mod+Shift+4 move container to workspace 4
bindsym $mod+Shift+5 move container to workspace 5

# Fullscreen
bindsym $mod+f fullscreen toggle

# Floating
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
floating_modifier $mod

# Increase volume by 5%
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%

# Decrease volume by 5%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%

# Mute/Unmute volume
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle

# Adjust screen brightness
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +5%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 5%-

# Screenshots
bindsym Print exec flameshot gui --path ~/Pictures/Screenshots
# Gaps
gaps inner 10
gaps outer 6

# Borders
default_border pixel 2
default_floating_border pixel 2

# Orange border for focused window
for_window [class="com.mitchellh.ghostty"] border pixel 2
client.focused          #FF8C00 #FF8C00 #ffffff #FF8C00 #FF8C00
client.unfocused        #FF8C00 #FF8C00 #ffffff #FF8C00 #FF8C00
client.focused_inactive #FF8C00 #FF8C00 #ffffff #FF8C00 #FF8C00

# Wallpaper
exec_always feh --bg-center ~/.dotfiles/.config/i3/solar.jpg

exec_always --no-startup-id picom


exec_always --no-startup-id $HOME/.config/polybar/launch.sh
